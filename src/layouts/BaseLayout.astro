---
import '../styles/global.css';
import { business } from '../data/business';
import type { Lang } from '../data/content';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** Ruta canónica de ESTA página (ej. '/', '/ca/', '/aviso-legal/') */
  path: string;
  /** Mapa idioma->ruta para hreflang. Si se omite, no se emiten alternates. */
  alternates?: Partial<Record<Lang, string>>;
  /** Inyecta JSON-LD (objeto o array de objetos) */
  jsonLd?: object | object[];
  /** Si true, emite robots noindex (páginas que no deben aparecer en Google) */
  noindex?: boolean;
}

const { lang, title, description, path, alternates, jsonLd, noindex } = Astro.props;

const site = business.url;
const canonical = new URL(path, site).href;
const ogLocale = lang === 'ca' ? 'ca_ES' : 'es_ES';

const schemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang recíproco -->
    {
      alternates &&
        Object.entries(alternates).map(([l, p]) => (
          <link rel="alternate" hreflang={l === 'ca' ? 'ca-ES' : 'es-ES'} href={new URL(p, site).href} />
        ))
    }
    {
      alternates && alternates.es && (
        <link rel="alternate" hreflang="x-default" href={new URL(alternates.es, site).href} />
      )
    }

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={business.name} />
    <meta property="og:image" content={new URL('/og-image.jpg', site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.jpg', site).href} />

    <meta name="theme-color" content="#c1502e" />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />

    <!-- JSON-LD -->
    {schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}

    <!-- Google Analytics 4 con Consent Mode: detectable, sin cookies de analítica hasta aceptar. -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${business.ga4Id}`}></script>
    <script is:inline define:vars={{ ga4Id: business.ga4Id }}>
      window.__GA4_ID__ = ga4Id;
      window.dataLayer = window.dataLayer || [];
      window.gtag = function () {
        window.dataLayer.push(arguments);
      };

      window.gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
      });
      window.gtag('js', new Date());

      function enableGA4() {
        if (!window.__GA4_ID__ || window.__GA4_ID__.startsWith('[') || window.__ga4Enabled__) return;
        window.__ga4Enabled__ = true;
        window.gtag('consent', 'update', {
          analytics_storage: 'granted',
        });
        window.gtag('config', window.__GA4_ID__, { anonymize_ip: true });
      }

      window.__loadGA4__ = enableGA4;
      if (localStorage.getItem('cookie-consent') === 'accepted') enableGA4();
    </script>
  </head>
  <body class="bg-crema text-tinta antialiased">
    <slot />
  </body>
</html>
