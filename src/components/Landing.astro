---
import { business, telHref, whatsappHref } from '../data/business';
import { content, type Lang } from '../data/content';
import Header from './Header.astro';
import Footer from './Footer.astro';
import FloatingWhatsApp from './FloatingWhatsApp.astro';
import ServiceCard from './ServiceCard.astro';
import TrustBadge from './TrustBadge.astro';
import FaqAccordion from './FaqAccordion.astro';
import CookieBanner from './CookieBanner.astro';
import Icon from './Icon.astro';
import { Image } from 'astro:assets';
import portada from '../assets/portada.jpg';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang];

const serviceIcons = ['panel', 'wire', 'switch'] as const;
const trustIcons = ['check', 'shield', 'clock'] as const;

// Mapa de Google embebido (dirección real, sin API key necesaria con el modo q=)
const mapQuery = encodeURIComponent(`${business.street}, ${business.postalCode} ${business.city}`);
const mapSrc = `https://www.google.com/maps?q=${mapQuery}&output=embed`;
---

<Header lang={lang} />

<main>
  <!-- ============ HERO (asimétrico, foto a sangre derecha) ============ -->
  <section class="relative overflow-hidden">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-14 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:py-20">
      <div>
        <p class="inline-flex items-center gap-2 rounded-full bg-teal/10 px-3 py-1 text-sm font-semibold text-teal">
          <Icon name="pin" class="h-4 w-4" />
          {t.hero.eyebrow}
        </p>
        <h1 class="mt-5 font-display text-4xl font-semibold leading-[1.1] text-tinta sm:text-5xl lg:text-6xl">
          {t.hero.h1}
        </h1>
        <p class="mt-5 max-w-xl text-lg text-tinta-muted">{t.hero.subtitle}</p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a
            href={telHref}
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-terracota px-6 py-3.5 text-base font-semibold text-crema shadow-warm transition hover:bg-terracota-dark"
            data-call-cta
          >
            <Icon name="phone" class="h-5 w-5 shrink-0" />
            {t.hero.callBtn}
          </a>
          <a
            href={whatsappHref()}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-teal px-6 py-3.5 text-base font-semibold text-teal transition hover:bg-teal hover:text-crema"
            data-whatsapp-cta
          >
            <Icon name="whatsapp" class="h-5 w-5 shrink-0" />
            {t.hero.whatsappBtn}
          </a>
        </div>
      </div>

      <!-- Foto: imagen real de cableado de un cuadro eléctrico. Esquina recortada distinta a los botones. -->
      <div class="relative">
        <Image
          src={portada}
          alt={t.hero.photoAlt}
          width={880}
          height={660}
          loading="eager"
          fetchpriority="high"
          sizes="(min-width: 1024px) 45vw, 100vw"
          class="aspect-[4/3] w-full rounded-tl-[2.5rem] rounded-br-[2.5rem] rounded-tr-xl rounded-bl-xl object-cover shadow-warm"
        />
      </div>
    </div>
  </section>

  <!-- ============ FRANJA DE CONFIANZA (a todo el ancho, sin reseñas: garantías reales) ============ -->
  <section class="border-y border-crema-200 bg-white/40">
    <div class="mx-auto grid max-w-6xl gap-4 px-4 py-8 sm:px-6 md:grid-cols-3">
      {t.trust.map((item, i) => <TrustBadge title={item.title} text={item.text} icon={trustIcons[i]} />)}
    </div>
  </section>

  <!-- ============ SERVICIOS ============ -->
  <section id="servicios" class="scroll-mt-20">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <h2 class="font-display text-3xl font-semibold text-tinta sm:text-4xl">{t.services.title}</h2>
      <p class="mt-3 max-w-2xl text-lg text-tinta-muted">{t.services.intro}</p>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {t.services.items.map((item, i) => <ServiceCard title={item.title} text={item.text} icon={serviceIcons[i]} />)}
      </div>
    </div>
  </section>

  <!-- ============ PROCESO (numerado, no rejilla abstracta) ============ -->
  <section id="proceso" class="scroll-mt-20 border-y border-crema-200 bg-white/40">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <h2 class="font-display text-3xl font-semibold text-tinta sm:text-4xl">{t.process.title}</h2>
      <p class="mt-3 max-w-2xl text-lg text-tinta-muted">{t.process.intro}</p>
      <ol class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          t.process.steps.map((step) => (
            <li class="relative rounded-2xl border border-crema-200 bg-white/60 p-6">
              <span class="font-display text-4xl font-semibold text-terracota/30">{step.n}</span>
              <h3 class="mt-2 font-display text-lg font-semibold text-tinta">{step.title}</h3>
              <p class="mt-1 text-sm text-tinta-muted">{step.text}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ============ POR QUÉ ELEGIRNOS ============ -->
  <section class="border-y border-crema-200 bg-teal/5">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-2">
      <div>
        <h2 class="font-display text-3xl font-semibold text-tinta sm:text-4xl">{t.why.title}</h2>
        <p class="mt-3 text-lg text-tinta-muted">{t.why.intro}</p>
      </div>
      <ul class="space-y-4">
        {
          t.why.points.map((point) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center rounded-full bg-teal text-crema">
                <Icon name="check" class="h-4 w-4" />
              </span>
              <span class="text-tinta">{point}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ ZONA DE COBERTURA ============ -->
  <section id="zona" class="scroll-mt-20">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <h2 class="font-display text-3xl font-semibold text-tinta sm:text-4xl">{t.zone.title}</h2>
      <p class="mt-3 max-w-2xl text-lg text-tinta-muted">{t.zone.text}</p>
      <p class="mt-6 text-sm font-semibold uppercase tracking-wide text-tinta-muted">{t.zone.listLabel}</p>
      <ul class="mt-3 flex flex-wrap gap-2">
        {
          business.areaServed.map((area) => (
            <li class="inline-flex items-center gap-1.5 rounded-full border border-crema-200 bg-white/60 px-3 py-1.5 text-sm text-tinta">
              <Icon name="pin" class="h-4 w-4 text-terracota" />
              {area}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section id="faq" class="scroll-mt-20 border-y border-crema-200 bg-white/40">
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
      <h2 class="font-display text-3xl font-semibold text-tinta sm:text-4xl">{t.faq.title}</h2>
      <div class="mt-8">
        <FaqAccordion items={t.faq.items} />
      </div>
    </div>
  </section>

  <!-- ============ CONTACTO ============ -->
  <section id="contacto" class="scroll-mt-20">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-2">
      <div>
        <h2 class="font-display text-3xl font-semibold text-tinta sm:text-4xl">{t.contact.title}</h2>
        <p class="mt-3 text-lg text-tinta-muted">{t.contact.intro}</p>

        <div class="mt-8 space-y-5">
          <a href={telHref} class="flex items-center gap-3 text-tinta" data-call-cta>
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-terracota text-crema"><Icon name="phone" class="h-5 w-5" /></span>
            <span>
              <span class="block text-xs uppercase tracking-wide text-tinta-muted">{t.contact.phoneLabel}</span>
              <span class="font-display text-xl font-semibold">{business.phoneDisplay}</span>
            </span>
          </a>
          <a href={`mailto:${business.email}`} class="flex items-center gap-3 text-tinta">
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-teal text-crema"><Icon name="mail" class="h-5 w-5" /></span>
            <span>
              <span class="block text-xs uppercase tracking-wide text-tinta-muted">{t.contact.emailLabel}</span>
              <span class="font-semibold">{business.email}</span>
            </span>
          </a>
          <div class="flex items-center gap-3 text-tinta">
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-tinta text-crema"><Icon name="pin" class="h-5 w-5" /></span>
            <span>
              <span class="block text-xs uppercase tracking-wide text-tinta-muted">{t.contact.addressLabel}</span>
              <span class="font-semibold">{business.street}, {business.postalCode} {business.city}</span>
            </span>
          </div>
          <div class="flex items-center gap-3 text-tinta">
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-crema-200 text-tinta"><Icon name="clock" class="h-5 w-5" /></span>
            <span>
              <span class="block text-xs uppercase tracking-wide text-tinta-muted">{t.contact.hoursLabel}</span>
              <span class="font-semibold">{business.openingHoursDisplay}</span>
            </span>
          </div>
        </div>
      </div>

      <div class="overflow-hidden rounded-2xl border border-crema-200 shadow-warm-sm">
        <iframe
          title={t.contact.mapTitle}
          src={mapSrc}
          width="100%"
          height="100%"
          style="min-height: 340px; border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>
</main>

<Footer lang={lang} />
<FloatingWhatsApp lang={lang} />
<CookieBanner lang={lang} />
