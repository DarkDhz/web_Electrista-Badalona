---
import { whatsappHref } from '../data/business';
import { content, type Lang } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const label = lang === 'ca' ? 'Escriure per WhatsApp' : 'Escribir por WhatsApp';
const _t = content[lang];
---

<!--
  WhatsApp flotante abajo a la derecha, en todos los tamaños.
  El CTA de llamar ya está en la navbar (Header), así que no se duplica aquí.
-->
<a
  href={whatsappHref()}
  target="_blank"
  rel="noopener"
  aria-label={label}
  title={label}
  data-whatsapp-cta
  class="fixed bottom-6 right-6 z-50 grid h-14 w-14 place-items-center rounded-full bg-teal text-crema shadow-warm transition hover:scale-105 hover:bg-teal-dark"
>
  <Icon name="whatsapp" class="h-7 w-7" />
</a>
