---
import type { FaqItem } from '../data/content';

interface Props {
  items: FaqItem[];
}
const { items } = Astro.props;
---

<div class="divide-y divide-crema-200 overflow-hidden rounded-2xl border border-crema-200 bg-white/60">
  {
    items.map((item) => (
      <details class="group">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 font-display text-lg font-semibold text-tinta transition hover:text-terracota [&::-webkit-details-marker]:hidden">
          {item.q}
          <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full border border-crema-200 text-tinta-muted transition group-open:rotate-45 group-open:border-terracota group-open:text-terracota" aria-hidden="true">
            +
          </span>
        </summary>
        <div class="px-5 pb-5 text-tinta-muted">{item.a}</div>
      </details>
    ))
  }
</div>
