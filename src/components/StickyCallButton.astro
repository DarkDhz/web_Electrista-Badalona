---
import { telHref, whatsappHref } from '../data/business';
import { content, type Lang } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang];
---

<!-- Barra fija inferior en móvil: la mayoría de búsquedas son urgentes y desde el teléfono -->
<div class="fixed inset-x-0 bottom-0 z-50 grid grid-cols-2 gap-px border-t border-crema-200 bg-crema-200 md:hidden">
  <a
    href={telHref}
    class="flex items-center justify-center gap-2 bg-terracota py-3.5 font-semibold text-crema"
    data-call-cta
  >
    <Icon name="phone" class="h-5 w-5" />
    {t.stickyCall}
  </a>
  <a
    href={whatsappHref()}
    class="flex items-center justify-center gap-2 bg-teal py-3.5 font-semibold text-crema"
    data-whatsapp-cta
    target="_blank"
    rel="noopener"
  >
    <Icon name="whatsapp" class="h-5 w-5" />
    WhatsApp
  </a>
</div>
<!-- Espaciador para que la barra fija no tape contenido en móvil -->
<div class="h-14 md:hidden" aria-hidden="true"></div>
